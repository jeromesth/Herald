{
	"name": "heraldjs",
	"version": "0.6.0",
	"description": "Open-source headless notification system for TypeScript. Build notification workflows on your own infrastructure.",
	"type": "module",
	"main": "./dist/index.mjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.mjs"
		},
		"./prisma": {
			"types": "./dist/adapters/database/prisma.d.ts",
			"default": "./dist/adapters/database/prisma.mjs"
		},
		"./inngest": {
			"types": "./dist/adapters/workflow/inngest.d.ts",
			"default": "./dist/adapters/workflow/inngest.mjs"
		},
		"./postgres": {
			"types": "./dist/adapters/workflow/postgres.d.ts",
			"default": "./dist/adapters/workflow/postgres.mjs"
		},
		"./drizzle": {
			"types": "./dist/adapters/database/drizzle.d.ts",
			"default": "./dist/adapters/database/drizzle.mjs"
		},
		"./upstash": {
			"types": "./dist/adapters/workflow/upstash.d.ts",
			"default": "./dist/adapters/workflow/upstash.mjs"
		},
		"./memory": {
			"types": "./dist/adapters/memory.d.ts",
			"default": "./dist/adapters/memory.mjs"
		},
		"./api": {
			"types": "./dist/api/index.d.ts",
			"default": "./dist/api/index.mjs"
		},
		"./channels": {
			"types": "./dist/channels/index.d.ts",
			"default": "./dist/channels/index.mjs"
		},
		"./channels/email": {
			"types": "./dist/channels/email/index.d.ts",
			"default": "./dist/channels/email/index.mjs"
		},
		"./templates": {
			"types": "./dist/templates/index.d.ts",
			"default": "./dist/templates/index.mjs"
		}
	},
	"files": ["dist", "README.md", "LICENSE"],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"clean": "rm -rf dist",
		"prepack": "cp ../../README.md ./README.md && cp ../../LICENSE ./LICENSE",
		"postpack": "rm -f ./README.md ./LICENSE"
	},
	"dependencies": {
		"zod": "^3.24.0"
	},
	"devDependencies": {
		"@prisma/client": "^6.0.0",
		"drizzle-orm": "^0.45.1",
		"inngest": "^3.0.0",
		"tsup": "^8.4.0",
		"typescript": "^5.7.0"
	},
	"peerDependencies": {
		"@prisma/client": ">=5.0.0",
		"drizzle-orm": ">=0.30.0",
		"inngest": ">=3.0.0",
		"@upstash/workflow": ">=0.1.0",
		"pg": ">=8.0.0"
	},
	"peerDependenciesMeta": {
		"@prisma/client": {
			"optional": true
		},
		"drizzle-orm": {
			"optional": true
		},
		"inngest": {
			"optional": true
		},
		"@upstash/workflow": {
			"optional": true
		},
		"pg": {
			"optional": true
		}
	},
	"keywords": [
		"notifications",
		"workflow",
		"typescript",
		"inngest",
		"headless",
		"prisma",
		"novu-alternative",
		"knock-alternative",
		"email",
		"sendgrid",
		"postgres",
		"drizzle",
		"upstash",
		"qstash",
		"resend",
		"postmark",
		"ses",
		"sse",
		"real-time",
		"templates"
	],
	"license": "MIT",
	"author": "Jerome St-Hilaire",
	"homepage": "https://github.com/jeromesth/herald#readme",
	"bugs": {
		"url": "https://github.com/jeromesth/herald/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/jeromesth/herald.git",
		"directory": "packages/core"
	},
	"sideEffects": false
}
